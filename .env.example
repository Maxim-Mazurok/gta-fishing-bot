# Set to false to disable inventory shift+click entirely
INVENTORY_ENABLED=true

# Grid slot to shift+click (1-indexed row and column)
INVENTORY_ROW=1
INVENTORY_COL=4

# Boot offload: periodically open vehicle boot and transfer fish into it
BOOT_OFFLOAD_ENABLED=false
# Seconds between offloads (default: 3600 = 1 hour)
BOOT_OFFLOAD_INTERVAL=3600
# Number of shift+clicks per offload (default: 20)
BOOT_OFFLOAD_CLICKS=20
# Seconds between each shift+click (default: 1.0)
BOOT_OFFLOAD_CLICK_DELAY=1.0

# Boot load: take items FROM vehicle boot INTO personal inventory
BOOT_LOAD_ENABLED=false
# Target item count in the monitored inventory cell — stop when reached
BOOT_LOAD_TARGET_COUNT=200
# Cell in vehicle boot grid to shift+click FROM (1-indexed row and column)
BOOT_LOAD_BOOT_ROW=1
BOOT_LOAD_BOOT_COL=1
# Cell in personal inventory to monitor count ON (1-indexed row and column)
BOOT_LOAD_INV_ROW=1
BOOT_LOAD_INV_COL=4
# Seconds between each shift+click (default: 1.0)
BOOT_LOAD_CLICK_DELAY=1.0
